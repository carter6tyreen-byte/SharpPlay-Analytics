# Configure logging
logging.basicConfig(level=logging.INFO)

API_KEY = os.getenv("RAPIDAPI_KEY", "your_default_api_key_here")

def fetch_sports_data():
    """Fetches raw sports statistics or daily schedule."""
    url = "https://your-mlb-api-endpoint.p.rapidapi.com/schedule" # Replace with your active endpoint
    headers = {
        "X-RapidAPI-Key": API_KEY,
        "X-RapidAPI-Host": "your-mlb-api-host.p.rapidapi.com"
    }
    try:
        response = requests.get(url, headers=headers)
        response.raise_for_status()
        return response.json()
    except Exception as e:
        logging.error(f"Error fetching sports data: {e}")
        return {}

